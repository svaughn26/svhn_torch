      "source": [
        "import torch\n",
        "import torch.nn as nn\n",
        "\n",
        "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "\n",
        "model = SVHNCNN().to(device)\n",
        "model.load_state_dict(torch.load(\"svhn_cnn.pth\", map_location=device))\n",
        "model.eval()\n",
        "\n",
        "dummy = torch.randn(1, 3, 32, 32).to(device)  # SVHN is 32x32 RGB\n",
        "\n",
        "torch.onnx.export(\n",
        "    model,\n",
        "    dummy,\n",
        "    \"svhn_cnn.onnx\",\n",
        "    input_names=[\"input\"],\n",
        "    output_names=[\"logits\"],\n",
        "    opset_version=11\n",
        ")"
      ]
    },
